# === API Key (VNG Cloud MaaS) ===
MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# === LLM Settings ===
LLM_PROVIDER=minimax
LLM_MODEL=minimax/minimax-m2.5
LLM_TEMPERATURE=0.2

# === Browser Settings ===
BROWSER_TYPE=chromium
HEADLESS=false
STEALTH=true
VIEWPORT=1920,1080
TIMEOUT=30000

# === Server Settings ===
HOST=0.0.0.0
PORT=8000
DEBUG=false
